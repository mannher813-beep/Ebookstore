# --- App URL Configuration ---
# AI Studio automatically injects APP_URL at runtime (e.g. https://ais-dev-...).
# This is used for webhooks and callback URLs.
APP_URL="https://your-applet-domain.com"
SITE_URL="https://your-applet-domain.com"

# --- Supabase Configuration ---
# Your Supabase project API URL (e.g., https://xyz.supabase.co)
VITE_SUPABASE_URL="https://your-supabase-project.supabase.co"

# Your Supabase Anon Key (safe for frontend use)
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Your Supabase Service Role Key (strictly server-side, never expose to browser!)
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# --- MoneyFusion Configuration ---
# MoneyFusion Payment API Endpoint (e.g., https://www.pay.moneyfusion.net/paiement)
MONEYFUSION_API_URL="https://www.pay.moneyfusion.net/paiement"

# MoneyFusion private key or other authentication token if required
MONEYFUSION_PRIVATE_KEY="your-moneyfusion-private-key"
